@prefix rr:  <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:  <http://semweb.mmlab.be/ns/ql#> .
@prefix carml: <http://carml.taxman.nl/carml#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .
@prefix eph: <http://rdf.geohistoricaldata.org/id/museeCarnavalet/ephemeres/> .
@prefix fn: <http://www.w3.org/2005/xpath-functions> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix dcterms: <http://purl.org/dc/terms/>.


<#recordMap>
  a rr:TriplesMap ;

  rml:logicalSource [
    rml:source "echantillon.xml" ;
    rml:referenceFormulation ql:XPath ;
    rml:iterator "/adlibXML/recordList/record" ;
  ] ;

  rr:subjectMap [
    rr:template "http://rdf.geohistoricaldata.org/id/museeCarnavalet/ephemeres/record/{object_number}" ;
    rr:class rico:Record
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:title ;
    rr:objectMap [ rml:reference "Title/title" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:generalDescription ;
    rr:objectMap [ rml:reference "Content_icon/description.iconographical_description" ]
  ] ;
  
  rr:predicateObjectMap [
    rr:predicate rico:identifier ;
    rr:objectMap [ rml:reference "object_number" ]
  ] ;

   rr:predicateObjectMap [
    rr:predicate rico:note ;
    rr:objectMap [ 
      rml:reference "Inscription[normalize-space(lower-case(inscription.notes)) = 'impression']/analyze-string(inscription.transliteration, '\"(.+?)\"')//*:group[@nr=1]  ! normalize-space(.)"
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:hasOrHadSubject ;
    rr:objectMap [ 
      rml:reference "tokenize(themes_sujets.theme_commentaire, ',') ! normalize-space(.)"
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:hasCreationDate ;
    rr:objectMap [ 
      a rr:RefObjectMap ;
      rr:parentTriplesMap <#MappingDateBlankNode>
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:relation ;
    rr:objectMap [
      rml:reference "Reproduction/reproduction.file ! normalize-space(.)" 
    ]
  ] .

<#MappingDateBlankNode>
  a rr:TriplesMap ;

  rml:logicalSource [
    rml:source "echantillon.xml" ;
    rml:referenceFormulation ql:XPath ;
    rml:iterator "/adlibXML/recordList/record" ;
  ] ;

  rr:subjectMap [
    rr:termType rr:BlankNode ;
    rml:reference "object_number" ;
    rr:class rico:Date
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:beginningDate ;
    rr:objectMap [
      rml:reference "Production/production.date.start"
    ]
  ] ;
  
  rr:predicateObjectMap [
    rr:predicate rico:endDate ;
    rr:objectMap [
      rml:reference "Production/production.date.end"
    ]
  ] .

<#MappingRelationDessinateur>
  a rr:TriplesMap ;

  rml:logicalSource [
    rml:source "echantillon.xml" ;
    rml:referenceFormulation ql:XPath ;
    rml:iterator "/adlibXML/recordList/record" ;
  ] ;

  rr:subjectMap [
    rr:template "http://rdf.geohistoricaldata.org/id/museeCarnavalet/ephemeres/dessin/{object_number}" ;
    rr:class rico:CreationRelation
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:withCreationRole ;
    rr:object <http://data.culture.fr/thesaurus/resource/ark:/67717/T513-32850>
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:relationHasSource ;
    rr:objectMap [
      rr:template "http://rdf.geohistoricaldata.org/id/museeCarnavalet/ephemeres/record/{object_number}"
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:relationHasTarget ;
    rr:objectMap [
      a rr:RefObjectMap ;
      rr:parentTriplesMap <#MappingPersonDessin>;

      rr:joinCondition [
        rr:child "object_number";
        rr:parent "../object_number"
      ]
    ]
  ] .

<#MappingPersonDessin>
  a rr:TriplesMap ;
  rml:logicalSource [
    rml:source "echantillon.xml" ;
    rml:referenceFormulation ql:XPath ;
    rml:iterator "/adlibXML/recordList/record/Production[lower-case(creator.role)='dessinateur']"
  ] ;

  rr:subjectMap [
    rr:termType rr:BlankNode ;
    rml:reference "creator";
    rr:class rico:Person
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:name ;
    rr:objectMap [ rml:reference "creator" ]
  ] .

  <#MappingRelationImprimeur>
  a rr:TriplesMap ;

  rml:logicalSource [
    rml:source "echantillon.xml" ;
    rml:referenceFormulation ql:XPath ;
    rml:iterator "/adlibXML/recordList/record" ;
  ] ;

  rr:subjectMap [
    rr:template "http://rdf.geohistoricaldata.org/id/museeCarnavalet/ephemeres/impression/{object_number}" ;
    rr:class rico:CreationRelation
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:withCreationRole ;
    rr:object <http://data.culture.fr/thesaurus/resource/ark:/67717/T513-32910>
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:productionTechnique ;
    rr:objectMap [ rml:reference "technique" ] 
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:relationHasSource ;
    rr:objectMap [
      rr:template "http://rdf.geohistoricaldata.org/id/museeCarnavalet/ephemeres/record/{object_number}"
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:relationHasTarget ;
    rr:objectMap [
      a rr:RefObjectMap ;
      rr:parentTriplesMap <#MappingPersonImprimeur> ;
      rr:joinCondition [
        rr:child "object_number" ;
        rr:parent "../object_number" 
      ]
    ]
  ] .

  <#MappingPersonImprimeur>
  a rr:TriplesMap ;
  rml:logicalSource [
    rml:source "echantillon.xml" ;
    rml:referenceFormulation ql:XPath ;
    # Filtrage sur le rôle Imprimeur
    rml:iterator "/adlibXML/recordList/record/Production[lower-case(creator.role)='imprimeur']"
  ] ;

  rr:subjectMap [
    rr:termType rr:BlankNode ;
    rml:reference "creator" ;
    rr:class rico:Person
  ] ;

  rr:predicateObjectMap [
    rr:predicate rico:name ;
    rr:objectMap [ rml:reference "creator" ]
  ] .

  <#ThesaurusDessinateur>
    rml:logicalSource [
        rml:source "echantillon.xml";
        rml:iterator "/adlibXML/recordList/record"; 
        rml:referenceFormulation ql:XPath
    ];

    rr:subjectMap [
        rr:constant <http://data.culture.fr/thesaurus/resource/ark:/67717/T513-32850>
    ];

    rr:predicateObjectMap [
        rr:predicate skos:prefLabel;
        rr:objectMap [ rr:constant "Dessinateur"; rr:language "fr" ]
    ].


  <#ThesaurusImprimeur>
    rml:logicalSource [
        rml:source "echantillon.xml"; 
        rml:iterator "/adlibXML/recordList/record"; 
        rml:referenceFormulation ql:XPath
    ];
    rr:subjectMap [
        rr:constant <http://data.culture.fr/thesaurus/resource/ark:/67717/T513-32910>
    ];

    rr:predicateObjectMap [
        rr:predicate skos:prefLabel;
        rr:objectMap [ rr:constant "Imprimeur"; rr:language "fr" ]
    ].


